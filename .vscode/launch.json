    "version": "0.2.0",
    "configurations": [
        {
            "name": "debug",
            "request": "launch",
            "type": "dart",
            "program": "lib/main.dart",
            "flutterMode": "debug"
        },
        {
            "name": "staging",
            "request": "launch",
            "type": "dart",
            "program": "lib/main_staging.dart",
            "flutterMode": "debug",
            "args": [
                "--dart-define-from-file", "config.json"
            ]
        },
        {
            "name": "profile",
            "request": "launch",
            "type": "dart",
            "program": "lib/main_staging.dart",
            "flutterMode": "profile",
            "args": [
                "--dart-define-from-file", "config.json"
            ]
        },
        {
            "name": "release",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release",
            "args": [
                "--dart-define-from-file", "config.json"
            ]
        }
    ]
}